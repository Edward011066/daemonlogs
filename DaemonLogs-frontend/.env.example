# Porta publicada no host para o container nginx do frontend.
# Se houver nginx externo na VPS, use 5000 e aponte o proxy_pass para 127.0.0.1:5000.
FRONTEND_PORT=5000

# URL base da API REST
# Dev:  http://localhost:3000
# Prod: https://api.seudominio.com
VITE_API_URL=http://localhost:3000

# Modo de autenticação — deve ser idêntico ao AUTH_MODE configurado no backend
# local   → login com username + password (padrão)
# discord → OAuth2 Discord
VITE_AUTH_MODE=local
