# Database
DATABASE_URL="postgresql://daemonlogs:changeme@localhost:5432/daemonlogs_db"
POSTGRES_USER=daemonlogs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=daemonlogs_db

# Auth
JWT_SECRET=changeme_use_a_random_256bit_secret_in_production
# JWT_SECRET use o código -> node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Auth Mode
# AUTH_MODE=local  → registro/login com username+password+email (padrão)
# AUTH_MODE=discord → OAuth2 Discord — não precisa de SMTP, email ou senha
AUTH_MODE=local

# Discord OAuth2 (apenas necessário quando AUTH_MODE=discord)
# Configure em https://discord.com/developers/applications → OAuth2 → Redirects
DISCORD_CLIENT_ID=           # Application ID do Discord Developer Portal
DISCORD_CLIENT_SECRET=       # Client Secret — NUNCA commitar em repositórios públicos
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback  # deve bater com o configurado no portal
DISCORD_OAUTH_FRONTEND_REDIRECT=http://localhost:5173/auth/callback  # rota do frontend que recebe ?token=JWT

# App
PORT=3000
NODE_ENV=development #development, production ou test
APP_URL=http://localhost:3000 #URL base da aplicação, usada para links em emails e redirecionamentos (ex: http://localhost:3000 para dev, https://app.daemonlogs.com para produção)
SWAGGER_ENABLED=true #false em produção para não expor /api-docs publicamente

# Email (SMTP)
# EMAIL_ENABLED=false desativa validação de domínio, envio de emails e exige ativação (útil para debug)
EMAIL_ENABLED=true #true ativa validação de domínio, envio de emails e exige configuração SMTP completa; false desativa tudo (útil para debug sem email)
SMTP_HOST=smtp.gmail.com #. Use smtp.gmail.com para Gmail, smtp.office365.com para Outlook/Hotmail, ou o host SMTP do seu provedor de email.
SMTP_PORT=587 #. 587 é a porta padrão para STARTTLS (recomendada para segurança), enquanto 465 é para SSL/TLS direto. Use 587 com SMTP_SECURE=false para melhor compatibilidade e segurança.
SMTP_SECURE=false # true para 465, false para outras portas
SMTP_USER=seu_email@gmail.com 
SMTP_PASS=sua_senha_de_app #senha de app é recomendada para maior segurança, especialmente com 2FA ativado
SMTP_FROM=noreply@seudominio.com #email de remetente para envio de emails (ex: noreply@seudominio.com)
ACTIVATION_CODE_TTL_MINUTES=60 #minutos de validade do token de ativação
PASSWORD_RESET_TTL_MINUTES=15 #minutos de validade do token de reset de senha

# Domínios de email permitidos (separados por vírgula)
ALLOWED_EMAIL_DOMAINS=gmail.com,outlook.com,hotmail.com,yahoo.com
# Domínios de email temporário bloqueados (separados por vírgula)
BLOCKED_EMAIL_DOMAINS=10minutemail.com,guerrillamail.com,temp-mail.org,mailinator.com,firemail.com.br,throwam.com,yopmail.com,dispostable.com

# Sistema de indicações — número de indicações bem-sucedidas para ganhar 30 dias de premium
REFERRAL_PREMIUM_THRESHOLD=5

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=120 #máximo de requisições por janela de tempo (global, todas as rotas)
RATE_LIMIT_WINDOW_MS=60000 #janela de tempo em milissegundos para o limite global (60000 = 1 minuto)

# my-token cooldown
MY_TOKEN_COOLDOWN_HOURS=24 #horas de cooldown antes de poder deletar ou rotacionar um my-token válido

# Woovi PIX
WOOVI_API_KEY=your_woovi_app_id # AppID da API/Plugin Woovi. Vai no header Authorization sem Bearer.
WOOVI_WEBHOOK_SECRET=        # opcional: secret key do metodo legado X-OpenPix-Signature (HMAC). O projeto valida por padrao o x-webhook-signature atual da Woovi.
WOOVI_CHARGE_VALUE_CENTS=3990     #valor da cobrança em centavos (ex: 3990 para R$39,90)
WOOVI_CHARGE_EXPIRY_SECONDS=60    #Expirar cobrança em 60 segundos #validade da cobrança PIX em segundos — 3600 = 1 hora (padrão)

# Token Validator Worker
TOKEN_CHECK_INTERVAL_HOURS=6   # horas entre cada ciclo de verificação de tokens (padrão: 6)
TOKEN_CHECK_DELAY_MS=5000      # delay em ms entre a verificação de cada token individual (padrão: 5000)
INTERNAL_SECRET=changeme_use_a_random_secret  # segredo compartilhado entre API e worker — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_INTERNAL_URL=http://api:3000  # URL interna da API usada pelo worker dentro da rede Docker
