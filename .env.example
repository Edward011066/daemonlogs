# ══════════════════════════════════════════════════════════════════════════════
# .env — Stack completa DaemonLogs (frontend + backend + banco de dados)
#
# Este arquivo é lido pelo docker-compose.yml na RAIZ do projeto.
# Um único .env configura tudo: backend, frontend e PostgreSQL.
#
# Para VPSs separadas, configure individualmente:
#   DaemonLogs-backend/.env   → backend + banco  (usa DaemonLogs-backend/docker-compose.yml)
#   DaemonLogs-frontend/.env  → frontend         (usa DaemonLogs-frontend/docker-compose.prod.yml)
#
# Como usar:
#   cp .env.example .env
#   # edite o .env com seus valores reais
#   docker compose up --build -d
# ══════════════════════════════════════════════════════════════════════════════


# ── Compose ───────────────────────────────────────────────────────────────────
# Porta exposta pelo container frontend no host.
# Se voce usar nginx externo na VPS, o mais comum e deixar 5000 aqui
# e apontar o proxy_pass do nginx para http://127.0.0.1:5000
FRONTEND_PORT=5000


# ── Frontend (Vite — variáveis baked no build) ────────────────────────────────

# Modo de autenticação — deve ser idêntico ao AUTH_MODE abaixo
# local   → login com username + password (padrão)
# discord → OAuth2 Discord
VITE_AUTH_MODE=local

# VITE_API_URL não precisa ser configurado aqui:
# O nginx do compose faz proxy de /api/* → api:3000 (rede interna)


# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
# DATABASE_URL é construído automaticamente — não defina aqui.
# O compose combina POSTGRES_* em runtime com URL-encoding correto da senha.

POSTGRES_USER=daemonlogs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=daemonlogs_db


# ── Autenticação ──────────────────────────────────────────────────────────────

# Segredo para assinar os JWTs — use um valor aleatório longo em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme_use_a_random_256bit_secret_in_production

# Modo de autenticação do backend (deve ser igual ao VITE_AUTH_MODE acima)
# local   → registro/login com username + password + email
# discord → OAuth2 Discord (não precisa de SMTP nem de senha)
AUTH_MODE=local


# ── Discord OAuth2 (apenas quando AUTH_MODE=discord) ─────────────────────────
# Configure em https://discord.com/developers/applications → OAuth2 → Redirects

DISCORD_CLIENT_ID=                                            # Application ID do Discord Developer Portal
DISCORD_CLIENT_SECRET=                                        # Client Secret — NUNCA commitar em repos públicos
DISCORD_REDIRECT_URI=https://seudominio.com/api/auth/discord/callback   # deve bater com o portal
DISCORD_OAUTH_FRONTEND_REDIRECT=https://seudominio.com/auth/callback   # rota do frontend que recebe ?token=JWT


# ── Aplicação ─────────────────────────────────────────────────────────────────

# ATENÇÃO: PORT deve ser 3000 — o nginx interno faz proxy para api:3000
# Alterar esta porta quebra o proxy do nginx
PORT=3000

NODE_ENV=production

# URL base pública da aplicação (usada em links de email e redirecionamentos)
APP_URL=https://seudominio.com/

# false em produção para não expor /api-docs publicamente
SWAGGER_ENABLED=false


# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# EMAIL_ENABLED=false → sem envio de emails, sem validação de domínio
# EMAIL_ENABLED=true  → requer configuração SMTP completa abaixo

EMAIL_ENABLED=false

SMTP_HOST=smtp.gmail.com          # smtp.gmail.com, smtp.office365.com, etc.
SMTP_PORT=587                     # 587 (STARTTLS) ou 465 (SSL direto)
SMTP_SECURE=false                 # true para porta 465, false para 587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app        # Use "senha de app" com 2FA ativado no Gmail
SMTP_FROM=noreply@seudominio.com

ACTIVATION_CODE_TTL_MINUTES=60   # validade do link de ativação de conta
PASSWORD_RESET_TTL_MINUTES=15    # validade do link de reset de senha

# Domínios de email permitidos no cadastro (separados por vírgula)
ALLOWED_EMAIL_DOMAINS=gmail.com,outlook.com,hotmail.com,yahoo.com

# Domínios de email temporário bloqueados (separados por vírgula)
BLOCKED_EMAIL_DOMAINS=10minutemail.com,guerrillamail.com,temp-mail.org,mailinator.com,throwam.com,yopmail.com,dispostable.com


# ── Sistema de indicações ─────────────────────────────────────────────────────
# Quantas indicações bem-sucedidas para ganhar 30 dias de premium
REFERRAL_PREMIUM_THRESHOLD=5


# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=120         # máximo de requisições por janela (global)
RATE_LIMIT_WINDOW_MS=60000        # janela em ms (60000 = 1 minuto)


# ── My Token ──────────────────────────────────────────────────────────────────
MY_TOKEN_COOLDOWN_HOURS=24        # horas de cooldown para deletar/rotacionar token


# ── Woovi PIX ─────────────────────────────────────────────────────────────────
#
# PASSO A PASSO PARA CONFIGURAR:
#
# 1. Acesse https://app.woovi.com → menu "API/Plugins" → abra sua aplicação
#
# 2. WOOVI_API_KEY → copie o AppID da API/Plugin.
#    Segundo a documentacao atual da Woovi, o AppID deve ser enviado
#    no header Authorization sem prefixo Bearer.
#
# 3. WOOVI_WEBHOOK_SECRET → opcional.
#    Este projeto valida por padrao o header x-webhook-signature
#    usando a chave publica oficial da Woovi.
#    Preencha WOOVI_WEBHOOK_SECRET apenas se voce quiser manter
#    compatibilidade com o metodo antigo/depreciado X-OpenPix-Signature (HMAC).
#
# 4. Configure o webhook no painel Woovi:
#    - API/Plugins → Webhooks → Criar webhook
#    - Evento:  OPENPIX:CHARGE_COMPLETED
#    - URL:     https://seudominio.com/api/webhooks/woovi
#              ↑ ATENÇÃO: deve terminar em /api/webhooks/woovi
#              ↑ NÃO é apenas o domínio raiz
#
# 5. O Docker e o nginx externo devem estar funcionando antes de salvar o webhook,
#    pois a Woovi envia um teste e espera HTTP 200.
#
WOOVI_API_KEY=                    # AppID da API/Plugin Woovi (header Authorization, sem Bearer)
WOOVI_WEBHOOK_SECRET=             # Opcional: secret key do metodo legado X-OpenPix-Signature (HMAC)
WOOVI_CHARGE_VALUE_CENTS=2000     # Valor da cobrança em centavos (2000 = R$20,00)
WOOVI_CHARGE_EXPIRY_SECONDS=3600  # Validade da cobrança PIX em segundos (3600 = 1 hora)
